# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
LAB_NAME="LAB"
LAB_URL="https://lab.edu.ar"

# NextAuth / Auth.js configuration
AUTH_SECRET="your_next_auth_secret_placeholder"

AUTH_GOOGLE_ID="your_google_oauth_id_placeholder"
AUTH_GOOGLE_SECRET="your_google_oauth_secret_placeholder"

# GitHub OAuth (Optional, uncomment and fill to enable)
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# Microsoft OAuth (Entra ID) (Optional, uncomment and fill to enable)
# AUTH_MICROSOFT_ENTRA_ID_ID=""
# AUTH_MICROSOFT_ENTRA_ID_SECRET=""

# ORCID OAuth (OIDC) (Optional, uncomment and fill to enable)
# AUTH_ORCID_ISSUER="https://sandbox.orcid.org"
# AUTH_ORCID_ID=""
# AUTH_ORCID_SECRET=""

# This api_key is used in the AI assistant (memorias chatbot) and for some automated tasks
# such as auto-tagging
OPENAI_API_KEY=""

# This read only databse access is used by the AI assistant (memorias chatbot)
DATABASE_READONLY_URL="postgres://memorias_readonly:memorias_readonly_password_secure_2026@localhost:51214/template1?sslmode=disable"

# Development-only: Toggle to highlight all elements annotated with data-component-semantics attribute on hover (2px, red outline)
NEXT_PUBLIC_HIGHLIGHT_SEMANTIC_COMPONENTS="false"

# Optional URL pointing to the Copilot system. If set, adds a "Copilot" entry in the Reports menu.
# COPILOT_URL="http://localhost:3001"

# SMTP Mail Delivery Settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false" # set "true" for port 465 (SSL/TLS), or "false" for port 587 (STARTTLS)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="LIFIA Memorias"
SMTP_FROM_EMAIL="noreply@lifia.info.unlp.edu.ar"


