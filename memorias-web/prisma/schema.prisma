// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  name                   String?
  role                   Role      @default(USER)
  active                 Boolean   @default(false) // Must be activated by admin
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  
  // New Preferences Fields
  notificationEmail      String?
  avatarUrl              String?
  digestEmails           Boolean   @default(true)
  immediateNotifications Boolean   @default(true)
  
  memberId      String?   @unique
  member        Member?   @relation(fields: [memberId], references: [id])

  accounts      Account[]
  sessions      Session[]
  reports       Report[]
}

enum Role {
  USER
  EDITOR
  ADMIN
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Member {
  id                  String    @id @default(uuid())
  firstName           String
  lastName            String
  // Slugs provide stable, meaningful URLs and can be manually edited
  slug                String    @unique
  
  // Date types map perfectly to UI Date Pickers
  startDate           DateTime? @db.Date
  endDate             DateTime? @db.Date
  
  // Professional Details
  highestDegree       String?
  coursesAtUNLP       String?
  positionAtLab       String? // Configurable list
  positionAtUnlp      String? // Configurable list
  category            String?
  sicadiCategory      String?
  positionAtCIC       String? // Configurable list
  positionAtCONICET   String? // Configurable list
  
  // Contact & Social
  personalEmail       String?
  institutionalEmail  String?
  phone               String?
  webPage             String?
  orcid               String?
  dblpProfile         String?
  googleResearchProfile String?
  researchGateProfile String?
  
  // Bios
  shortCvInSpanish    String?
  shortCvInEnglish    String?
  interestsInEnglish  String?
  interestsInSpanish  String?
  affiliations        String?
  notes               String?
  avatarUrl           String?
  tags                String[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt
  
  // Relations
  user                User?
  projects            Project[] @relation("ProjectMembers")
  theses              Thesis[]  @relation("ThesisMembers")
  scholarships        Scholarship[] @relation("ScholarshipMembers")
  publications        Publication[] @relation("PublicationMembers")
}

model Project {
  id               String    @id @default(uuid())
  title            String
  code             String?
  slug             String    @unique
  startDate        DateTime? @db.Date
  endDate          DateTime? @db.Date
  director         String?
  coDirector       String?
  responsibleGroup String?
  fundingAgency    String?
  amount           String?
  summary          String?
  website          String?

  tags             String[]
  featured         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  members          Member[]  @relation("ProjectMembers")
  theses           Thesis[]  @relation("ProjectTheses")
  scholarships     Scholarship[] @relation("ProjectScholarships")
  publications     Publication[] @relation("ProjectPublications")
}

model Thesis {
  id               String    @id @default(uuid())
  title            String
  slug             String    @unique
  career           String?
  level            String?   // Configurable list (e.g. PhD, Masters, Grade)
  student          String?
  director         String?
  coDirector       String?
  otherAdvisors    String?
  startDate        DateTime? @db.Date
  endDate          DateTime? @db.Date
  summary          String?
  reportUrl        String?
  progress         Int?      // 10, 20, ..., 100 (representing % in steps of 10)
  keywords         String?
  website          String?

  tags             String[]
  featured         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  members          Member[]  @relation("ThesisMembers")
  projects         Project[] @relation("ProjectTheses")
  publications     Publication[] @relation("ThesisPublications")
  scholarships     Scholarship[] @relation("ThesisScholarships")
}

model Scholarship {
  id               String    @id @default(uuid())
  title            String
  slug             String    @unique
  type             String?   // Configurable list
  student          String?
  director         String?
  coDirector       String?
  fundingAgency    String?
  startDate        DateTime? @db.Date
  endDate          DateTime? @db.Date
  summary          String?

  tags             String[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  members          Member[]  @relation("ScholarshipMembers")
  projects         Project[] @relation("ProjectScholarships")
  theses           Thesis[]  @relation("ThesisScholarships")
}

model Publication {
  id               String    @id @default(uuid())
  slug             String    @unique
  
  // We duplicate core BibTex fields here for fast indexing, sorting, and filtering
  type             String    // article, inproceedings, etc.
  title            String
  authors          String
  year             Int
  
  // Extra fields that aren't standard in BibTex
  ranking          String?
  selfArchivingUrl String?
  
  // The complete, original Bibtex data backing this publication
  bibtexData       Json      
  
  tags             String[]
  featured         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  members          Member[]  @relation("PublicationMembers")
  projects         Project[] @relation("ProjectPublications")
  theses           Thesis[]  @relation("ThesisPublications")
}

model SystemOption {
  id        String   @id @default(uuid())
  listName  String   // Identified by: "positionAtLab" | "positionAtUnlp" | "positionAtCIC" | "positionAtCONICET" | "thesisLevel" | "scholarshipType"
  value     String
  createdAt DateTime @default(now())

  @@unique([listName, value])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // e.g. "CREATE", "UPDATE", "DELETE"
  entityType String   // e.g. "Member", "Project", "Thesis", "Scholarship", "Publication"
  entityId   String
  entitySlug String?
  userId     String?
  userEmail  String?
  details    String?  // Description of edits/fields modified
  createdAt  DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id        String   @id @default(uuid())
  title     String
  blocks    Json     // [{ id, type, content, filters, sort, etc. }]
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

