# PostgreSQL connection string — point to the container name on db-network
DATABASE_URL=postgresql://postgres:postgres@memorias-db:5432/memorias

# OpenAI
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# URL of the memorias-web app (used in links inside copilot responses)
MEMORIAS_WEB_BASE_URL=https://memorias.example.com

# Optional
SESSION_TIMEOUT_SECONDS=3600
