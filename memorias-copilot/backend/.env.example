# OpenAI API Key (required to access GPT completions)
OPENAI_API_KEY=your-api-key-here

# OpenAI Model configuration
OPENAI_MODEL=gpt-4o-mini

# Ephemeral session idle timeout (default: 1 hour)
SESSION_TIMEOUT_SECONDS=3600

# PostgreSQL connection string (read-only or default role for the copilot)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:51214/template1?sslmode=disable

# Memorias Web frontend base URL (for absolute link references in responses)
MEMORIAS_WEB_BASE_URL=http://localhost:3000


